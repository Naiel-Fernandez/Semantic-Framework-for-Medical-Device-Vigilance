    <!-- http://xmlns.com/foaf/0.1/Organization -->


    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Organization">
        <rdfs:comment xml:lang="en">A corporate or administrative entity.</rdfs:comment>
        <rdfs:label xml:lang="en">Organization</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#ActiveDevice -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#ActiveDevice">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Device"/>
        <owl:disjointWith rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#InVitroDiagnosticDevice"/>
        <rdfs:comment xml:lang="en">A medical device that relies on a source of electrical energy or any source of power.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#ActiveImplant -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#ActiveImplant">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#ImplantableDevice"/>
        <rdfs:comment xml:lang="en">An implantable device that relies on an energy source.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Implant</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#ContaminationRisk -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#ContaminationRisk">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Risk"/>
        <rdfs:comment xml:lang="en">Risk arising from biological or chemical contamination of the device.</rdfs:comment>
        <rdfs:label xml:lang="en">Contamination Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#CybersecurityRisk -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Risk"/>
        <rdfs:comment xml:lang="en">Risk arising from software vulnerabilities or unauthorized access.</rdfs:comment>
        <rdfs:label xml:lang="en">Cybersecurity Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Device -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Device">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#hasManufacturer"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A medical device according to the MDR/IVDR regulatory framework.</rdfs:comment>
        <rdfs:label xml:lang="en">Device</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#DiagnosticRisk -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Risk"/>
        <rdfs:comment xml:lang="en">Risk related to false positives or false negatives in IVD devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnostic Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#FSCA -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#FSCA">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#addressesIncident"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Field Safety Corrective Action taken to mitigate a risk.</rdfs:comment>
        <rdfs:label xml:lang="en">F S C A</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#ImplantableActiveDevice -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#ImplantableActiveDevice">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#ActiveDevice"/>
        <rdfs:comment xml:lang="en">An active medical device which is intended to be totally or partially introduced into the human body.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Active Device</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#ImplantableDevice -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Device"/>
        <rdfs:comment xml:lang="en">A device intended to be totally introduced into the human body through clinical intervention.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#InSituCorrection -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#InSituCorrection">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#FSCA"/>
        <rdfs:comment xml:lang="en">Action taken to correct or update a device without removing it from the user.</rdfs:comment>
        <rdfs:label xml:lang="en">In Situ Correction</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Device"/>
        <rdfs:comment xml:lang="en">A medical device intended by the manufacturer for the examination of specimens derived from the human body.</rdfs:comment>
        <rdfs:label xml:lang="en">In Vitro Diagnostic Device</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Incident -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Incident">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#associatedWithRisk"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#involvesDevice"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#reportedBy"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An adverse event or serious incident involving a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#InfectionRisk -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#InfectionRisk">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Risk"/>
        <rdfs:comment xml:lang="en">Risk of the patient developing an infection due to the device.</rdfs:comment>
        <rdfs:label xml:lang="en">Infection Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#InjuryRisk -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#InjuryRisk">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Risk"/>
        <rdfs:comment xml:lang="en">Risk of physical harm or tissue damage to the patient.</rdfs:comment>
        <rdfs:label xml:lang="en">Injury Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#InterferenceRisk -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#InterferenceRisk">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Risk"/>
        <rdfs:comment xml:lang="en">Risk due to electromagnetic or environmental interference.</rdfs:comment>
        <rdfs:label xml:lang="en">Interference Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#MalfunctionRisk -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#MalfunctionRisk">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Risk"/>
        <rdfs:comment xml:lang="en">Risk of the device failing to perform its intended function.</rdfs:comment>
        <rdfs:label xml:lang="en">Malfunction Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Manufacturer -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Manufacturer">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
        <rdfs:comment xml:lang="en">The corporate entity responsible for manufacturing the medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#MaterialRisk -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#MaterialRisk">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Risk"/>
        <rdfs:comment xml:lang="en">Risk related to the degradation, wear, or toxicity of the device materials.</rdfs:comment>
        <rdfs:label xml:lang="en">Material Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Recall -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Recall">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#FSCA"/>
        <rdfs:comment xml:lang="en">Action to return the medical device to the manufacturer or supplier.</rdfs:comment>
        <rdfs:label xml:lang="en">Recall</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Risk -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Risk">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#severity"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A potential hazard or clinical risk associated with the use of a device.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#SafetyAlert -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#SafetyAlert">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#FSCA"/>
        <rdfs:comment xml:lang="en">Communication sent to users detailing important safety information.</rdfs:comment>
        <rdfs:label xml:lang="en">Safety Alert</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#SelfTestDevice -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#SelfTestDevice">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#InVitroDiagnosticDevice"/>
        <rdfs:comment xml:lang="en">An IVD device intended by the manufacturer to be able to be used by lay persons.</rdfs:comment>
        <rdfs:label xml:lang="en">Self Test Device</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#SeriousIncident -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#SeriousIncident">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#Incident"/>
        <rdfs:comment xml:lang="en">An incident that directly or indirectly led to death or a serious deterioration in the state of health.</rdfs:comment>
        <rdfs:label xml:lang="en">Serious Incident</rdfs:label>
    </owl:Class>
    


    <!-- https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#UserNotice -->


    <owl:Class rdf:about="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#UserNotice">
        <rdfs:subClassOf rdf:resource="https://naiel-fernandez.github.io/Semantic-Framework-for-Medical-Device-Vigilance/doc#FSCA"/>
        <rdfs:comment xml:lang="en">A formal notification to users regarding device usage instructions.</rdfs:comment>
        <rdfs:label xml:lang="en">User Notice</rdfs:label>
    </owl:Class>
    


